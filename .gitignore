# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# Virtual environments
.venv/

# IDE
.idea/

# Logs
logs/

# Shared project skills live in skills/; .claude/skills and .cursor/skills
# are symlinks to that tree (tracked so Claude Code and Cursor both see them).
# Local-only settings under .claude/ / .cursor/ stay ignored.
.claude/*
!.claude/skills
.cursor/*
!.cursor/skills

# Databases
*.db
